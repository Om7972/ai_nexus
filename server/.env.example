# ────────────────────────────────────────────────────────────────────────────
#  AI-Nexus Server  –  Environment Variables Template (.env.example)
#
#  Copy this file to .env and fill in all values before starting the server.
#  The server will REFUSE to start if required variables are missing.
# ────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development           # development | test | production
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/ai_nexus

# ── JWT  (generate secrets with: node -e "require('crypto').randomBytes(32).toString('hex')" ) ──
JWT_SECRET=REPLACE_WITH_RANDOM_32+_CHAR_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_32+_CHAR_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CLIENT_ORIGIN=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes in ms
RATE_LIMIT_MAX=100             # requests per window per IP

# ── Security Secrets (CSRF + cookies) ────────────────────────────────────────
# Minimum 32 characters in production (enforced by Zod validator)
CSRF_SECRET=REPLACE_WITH_RANDOM_32+_CHAR_SECRET
COOKIE_SECRET=REPLACE_WITH_RANDOM_32+_CHAR_SECRET

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Development: use https://ethereal.email for a free fake inbox
# Production : Resend / Mailgun / SendGrid / SES
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user@ethereal.email
SMTP_PASS=your_ethereal_password
EMAIL_FROM=AI-Nexus <noreply@ainexus.dev>
