{
    "watch": [
        "*.js",
        "config",
        "controllers",
        "middlewares",
        "models",
        "routes",
        "services",
        "utils",
        "validators"
    ],
    "ext": "js,json",
    "ignore": [
        "node_modules",
        "logs"
    ],
    "exec": "node --no-deprecation",
    "env": {
        "NODE_ENV": "development"
    }
}